{
  "name": "@chocbite/ts-lib-base",
  "version": "1.4.0",
  "description": "Base ui library for TypeScript",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "style": "./dist/index.css",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "style": "./dist/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 9952",
    "build": "tsdown src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "check-trials": "tsc --noEmit",
    "prepublishOnly": "npm run check-trials && npm run build",
    "upgrades": "npx npm-check-updates --target semver",
    "upgrade": "npx npm-check-updates --target semver -u && npm install"
  },
  "devDependencies": {
    "@chocbite/ts-supplement-eslint": "^1.0.0",
    "@tsdown/css": "^0.21.7",
    "@vitest/browser-playwright": "^4.1.2",
    "eslint": "^10.1.0",
    "sass": "^1.98.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@chocbite/ts-lib-event": "^1.0.2",
    "@chocbite/ts-lib-result": "^1.3.0",
    "@chocbite/ts-lib-state": "^2.0.4"
  }
}
