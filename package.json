{
  "name": "@chocbite/ts-lib-base",
  "version": "1.1.0",
  "description": "Base ui library for TypeScript",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 9952",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "upgrades": "npx npm-check-updates",
    "upgrade": "npx npm-check-updates -u"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.0",
    "esbuild-sass-plugin": "^3.7.0",
    "eslint": "^10.0.3",
    "sass": "^1.98.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@chocbite/ts-lib-event": "^1.0.0",
    "@chocbite/ts-lib-result": "^1.0.0",
    "@chocbite/ts-lib-state": "^1.1.1"
  }
}
